@{
    ViewData["Title"] = "Packages";
}

<nav class="navbar navbar-expand-lg bg-info fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand text-black"
           asp-controller="Home"
           asp-action="Index">MKtravels</a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent">
            <span class="navbar-toggler-icon bg-light"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link active text-black"
                       asp-controller="Home"
                       asp-action="Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active text-black"
                       asp-controller="Home"
                       asp-action="Contactus">Contact Us</a>
                </li>
            </ul>

            <form class="d-flex" method="get" asp-action="Search" asp-controller="Home">
                <input class="form-control me-2" type="search"
                       placeholder="Search" name="query" />
                <button type="submit" class="btn btn-outline-success text-black">
                    Search
                </button>
            </form>
        </div>
    </div>
</nav>

<br />
<br />
<br />
<br />

<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 fw-bold text-light">
            Our Packages
        </h2>

        <div class="row g-4">

            <!-- Gold Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center">
                        <h3 class="text-warning fw-bold">🥇 Gold Package</h3>
                        <p class="mt-3">
                            Premium hotels, private sightseeing,
                            free breakfast & dinner.
                        </p>
                        <h5 class="fw-bold">₹18,999</h5>

                        <a asp-controller="Home"
                           asp-action="Gold"
                           class="btn btn-warning mt-3 text-dark fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Diamond Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center">
                        <h3 class="text-primary fw-bold">💎 Diamond Package</h3>
                        <p class="mt-3">
                            5-Star hotels, personal guide,
                            VIP entry, luxury experience.
                        </p>
                        <h5 class="fw-bold">₹29,999</h5>

                        <a asp-controller="Home"
                           asp-action="Diamond"
                           class="btn btn-primary mt-3 fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Silver Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center">
                        <h3 class="text-secondary fw-bold">🥈 Silver Package</h3>
                        <p class="mt-3">
                            Budget-friendly stay,
                            shared sightseeing, standard meals.
                        </p>
                        <h5 class="fw-bold">₹12,999</h5>

                        <a asp-controller="Home"
                           asp-action="Silver"
                           class="btn btn-secondary mt-3 fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Adventure Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center">
                        <h3 class="text-success fw-bold">🌄 Adventure Package</h3>
                        <p class="mt-3">
                            Trekking, water sports,
                            camping, adventure activities.
                        </p>
                        <h5 class="fw-bold">₹15,999</h5>

                        <a asp-controller="Home"
                           asp-action="Catebooking"
                           class="btn btn-success mt-3 fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Honeymoon Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center">
                        <h3 class="text-danger fw-bold">❤️ Honeymoon Package</h3>
                        <p class="mt-3">
                            Candlelight dinner,
                            honeymoon suite, romantic setup.
                        </p>
                        <h5 class="fw-bold">₹24,999</h5>

                        <a asp-controller="Home"
                           asp-action="Catebooking"
                           class="btn btn-danger mt-3 fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Weekend Package -->
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center bg-info">
                        <h3 class="text-black fw-bold">
                            ⏳ Weekend Package
                        </h3>
                        <p class="mt-3">
                            Short trips (2N/3D),
                            perfect for quick holidays.
                        </p>
                        <h5 class="fw-bold">₹9,999</h5>

                        <a asp-controller="Home"
                           asp-action="Catebooking"
                           class="btn btn-dark mt-3 fw-bold">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<footer class="bg-dark text-light py-4">
    <div class="container">
        <div class="row text-center text-md-start justify-content-between">

            <div class="col-md mb-3 h6">
                <h5>About Us</h5>
                <ul>
                    <li>"Explore the world with MKTravel"</li>
                    <li>"Your trusted travel partner."</li>
                    <li>"Discover. Travel. Experience – with MKTravel."</li>
                    <li>"Creating unforgettable journeys."</li>
                </ul>
            </div>

            <div class="col-md mb-3">
                <h5 class="text-center">Quick Links</h5>
                <ul class="list-unstyled text-center">
                    <li>
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="h5 text-light text-decoration-none">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Home"
                           asp-action="Login"
                           class="h5 text-light text-decoration-none">
                            Login
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Home"
                           asp-action="Contactus"
                           class="h5 text-light text-decoration-none">
                            Contact Us
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md mb-3 h5 text-center">
                <h5>Contact</h5>
                <p>Email: mktravels@gmail.com</p>
                <p>Phone: +91 9167517446</p>
            </div>

        </div>
    </div>
</footer>
