@{
    ViewData["Title"] = "Home";
}

<nav class="navbar navbar-expand-lg bg-info sticky-top">
    <div class="container-fluid">

        <!-- Logo -->
        <a class="navbar-brand text-black"
           asp-controller="Home" asp-action="Index">
            MKtravels
        </a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent">
            <span class="navbar-toggler-icon bg-light"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">

            <!-- Navbar Links -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link text-black"
                       asp-controller="Home" asp-action="Login">
                        Login
                    </a>
                </li>

                <!-- Packages Dropdown -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-black"
                       asp-controller="Home" asp-action="Packages"
                       data-bs-toggle="dropdown">
                        Packages
                    </a>

                    <ul class="dropdown-menu bg-dark-subtle">

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Home" asp-action="Packages">
                                Choose your packages
                            </a>
                        </li>

                        <li><hr class="dropdown-divider" /></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Home" asp-action="Diamond">
                                Diamond
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Home" asp-action="Gold">
                                Gold
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Home" asp-action="Silver">
                                Silver
                            </a>
                        </li>

                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-black"
                       asp-controller="Home" asp-action="Contactus">
                        Contact Us
                    </a>
                </li>

            </ul>

            <!-- Search Form -->
            <form class="d-flex" method="get" asp-controller="Home" asp-action="Search">
                <input class="form-control me-2"
                       type="search"
                       name="query"
                       placeholder="Search destinations" />

                <button type="submit"
                        class="btn btn-outline-success text-black">
                    Search
                </button>
            </form>

        </div>
    </div>
</nav>

<!-- Carousel -->
<div id="carouselExampleAutoplaying" class="carousel slide carousel-fade"
     data-bs-ride="carousel">

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="~/images/travel1.jpg" class="d-block w-100" />
        </div>

        <div class="carousel-item">
            <img src="~/images/travel2.jpg" class="d-block w-100" />
        </div>

        <div class="carousel-item">
            <img src="~/images/travel3.jpg" class="d-block w-100" />
        </div>

    </div>
</div>

<br />

<!-- Buttons -->
<div class="text-center">
    <a asp-controller="Home" asp-action="Jaipurdetails"
       class="btn btn-primary m-2">
        Jaipur Details
    </a>

    <a asp-controller="Home" asp-action="Lakshdeepdetails"
       class="btn btn-primary m-2">
        Lakshdeep Details
    </a>
</div>

<br /><br />

<!-- Footer -->
<footer class="bg-dark text-light py-4">
    <div class="container">

        <div class="row text-center text-md-start justify-content-between">

            <div class="col-md mb-3">
                <h5>About Us</h5>
                <ul>
                    <li>Explore the world with MKTravel</li>
                    <li>Your trusted travel partner</li>
                    <li>Discover. Travel. Experience</li>
                </ul>
            </div>

            <div class="col-md mb-3 text-center">
                <h5>Quick Links</h5>

                <a asp-controller="Home" asp-action="Index"
                   class="d-block text-light">Home</a>

                <a asp-controller="Home" asp-action="Packages"
                   class="d-block text-light">Packages</a>

                <a asp-controller="Home" asp-action="Contactus"
                   class="d-block text-light">Contact</a>
            </div>

           