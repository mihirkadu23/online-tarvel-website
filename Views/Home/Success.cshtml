<div class="card p-5 shadow">

    <h2 class="text-success">Payment Successful ✅</h2>

    <h4 class="mt-3">
        Booking ID :
        <span class="text-primary">@ViewBag.BookingId</span>
    </h4>

    <a asp-controller="Payment"
       asp-action="BookingDetails"
       asp-route-bookingId="@ViewBag.BookingId"
       class="btn btn-success mt-3">
        View Details
    </a>

</div>
